---
const { currentPath } = Astro.props;

const services = [
  { name: 'Broken Spring Repair', href: '/services/broken-springs' },
  { name: 'General Door Repair', href: '/services/door-repair' },
  { name: 'New Door Installation', href: '/services/new-door-installation' },
  { name: 'Opener Repair', href: '/services/opener-repair' },
  { name: 'Opener Installation', href: '/services/new-opener-installation' },
  { name: 'Maintenance & Safety', href: '/services/maintenance' },
];

// Removes the current page from the list
const otherServices = services.filter(service => service.href !== currentPath);
---

<div slot="full-width-section" class="special-footer-list-bg">
  <div class="special-footer-list-container">
    <h3>Our Other Services</h3>
    <nav class="special-footer-vertical-links">
      {otherServices.map(service => (
        <a href={service.href} class="special-footer-link">{service.name}</a>
      ))}
    </nav>
  </div>
</div>

<style>
  .special-footer-list-bg {
    background-color: #1a334f;
    padding: 3rem 0;
    width: calc(100%);
  }

  .special-footer-list-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1rem;
    text-align: left;
  }

  h3 {
    color: #ffffff;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 1px;
font-family: 'Lora', serif;
  }

  .special-footer-vertical-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .special-footer-link {
    color: #ffffff;
    text-decoration: none;
    font-size: .9rem;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .special-footer-link:hover {
    text-decoration: underline;
    opacity: 0.8;
  }
</style>