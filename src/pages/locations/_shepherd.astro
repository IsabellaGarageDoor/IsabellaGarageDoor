---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';

const title = "Garage Door Repair in Shepherd, MI | Isabella Garage Door";
const description = "Fast, local garage door repair in Shepherd, MI. Call Isabella Garage Door for owner-operated service you can trust. Serving Shepherd and surrounding areas.";

const shepherdSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://isabellagaragedoor.com/locations/shepherd",
      "url": "https://isabellagaragedoor.com/locations/shepherd",
      "name": "Garage Door Repair & Installation in Shepherd, MI",
      "isPartOf": { "@id": "https://isabellagaragedoor.com/#website" },
      "description": "Professional garage door repair services for residents of Shepherd, Michigan and the surrounding Coe Township area."
    },
    {
      "@type": "Service",
      "serviceType": "Garage Door Repair",
      "provider": { "@id": "https://isabellagaragedoor.com/#business" },
      "areaServed": {
        "@type": "City",
        "name": "Shepherd",
        "sameAs": "https://www.wikidata.org/wiki/Q954331" 
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Shepherd Service Offerings",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Broken Torsion Spring Repair" }
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Garage Door Opener Service" }
          }
        ]
      }
    }
  ]
};
---

<BaseLayout {title} {description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(shepherdSchema)} />
  </Fragment>

  <section>
    <h1>Garage Door Repair in Shepherd, MI</h1>
    <p>When your garage door isn’t working right, it disrupts everything. At Isabella Garage Door, we provide dependable, owner-operated garage door repair services right here in Shepherd. No call centers. No guesswork. Just local service you can count on.</p>
  </section>

  <section>
    <h2>Why Shepherd Residents Trust Us</h2>
    <ul>
      <li><strong>Locally owned:</strong> We're part of the community and take pride in helping our neighbors.</li>
      <li><strong>Owner-operated:</strong> You deal directly with the technician who shows up at your door.</li>
      <li><strong>Prompt & precise:</strong> We show up on time and get the job done right the first time.</li>
      <li><strong>No hidden fees:</strong> Our pricing is transparent, fair, and hassle-free.</li>
    </ul>
  </section>

  <section>
    <h2>Garage Door Services Offered</h2>
    <p>We repair and maintain residential garage doors throughout Shepherd and surrounding areas:</p>
    <ul>
      <li>Broken torsion and extension springs</li>
      <li>Garage door openers (repair & replacement)</li>
      <li>Snapped cables and worn-out rollers</li>
      <li>Misaligned or off-track doors</li>
      <li>Preventive maintenance and safety inspections</li>
    </ul>
  </section>

  <section>
    <h2>Fast, Friendly & Local</h2>
    <p>We’re based in Isabella County and proud to serve Shepherd homeowners with reliable, high-quality garage door work. Use our <a href="/easyestimate">EasyEstimate™</a> tool or reach out directly to schedule service.</p>
    <p><em>Raising Performance. Elevating Standards.</em></p>
  </section>
</BaseLayout>