const serviceAreaSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://isabellagaragedoor.com/locations/central-michigan",
      "url": "https://isabellagaragedoor.com/locations/central-michigan",
      "name": "Central Michigan Garage Door Services",
      "description": "Garage door repair, installation, and maintenance across Central Michigan by Isabella Garage Door. Locally owned, regionally trusted."
    },
    {
      "@type": "Service",
      "name": "Garage Door Repair & Installation",
      "provider": {
        "@id": "https://isabellagaragedoor.com/#business"
      },
      "description": "Providing reliable garage door repair, new door installation, opener replacement, and maintenance plans.",
      "areaServed": [
        { "@type": "City", "name": "Mt. Pleasant" },
        { "@type": "City", "name": "Clare" },
        { "@type": "City", "name": "Lake Isabella" },
        { "@type": "City", "name": "Beal City" },
        { "@type": "City", "name": "Shepherd" },
        { "@type": "City", "name": "Rosebush" },
        { "@type": "City", "name": "Remus" },
        { "@type": "City", "name": "Farwell" },
        { "@type": "City", "name": "Coleman" },
        { "@type": "City", "name": "St. Louis" },
        { "@type": "City", "name": "Alma" },
        { "@type": "City", "name": "Edmore" },
        { "@type": "City", "name": "Winn" }
