---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';

const title = "Garage Door Repair in Remus, MI | Isabella Garage Door";
const description = "Need garage door repair in Remus, MI? Isabella Garage Door offers fast, local service with honest pricing and quality workmanship.";

const remusSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://isabellagaragedoor.com/locations/remus",
      "url": "https://isabellagaragedoor.com/locations/remus",
      "name": "Garage Door Repair & Installation in Remus, MI",
      "isPartOf": { "@id": "https://isabellagaragedoor.com/#website" },
      "description": "Professional garage door repair services for homeowners in Remus, Michigan and the surrounding Wheatland Township area."
    },
    {
      "@type": "Service",
      "serviceType": "Garage Door Repair",
      "provider": { "@id": "https://isabellagaragedoor.com/#business" },
      "areaServed": {
        "@type": "City",
        "name": "Remus",
        "sameAs": "https://www.wikidata.org/wiki/Q7312154" 
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Remus Service Menu",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Spring Replacement & Adjustment" }
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Garage Door Opener Repair" }
          }
        ]
      }
    }
  ]
};
---

<BaseLayout {title} {description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(remusSchema)} />
  </Fragment>

  <section>
    <h1>Garage Door Repair in Remus, MI</h1>
    <p>If your garage door is acting up in Remus, we’re here to help. At Isabella Garage Door, we deliver fast, dependable repairs and honest service—without the big-company runaround. It’s just quality work from a local pro who knows the area.</p>
  </section>

  <section>
    <h2>Why Remus Homeowners Call Us</h2>
    <ul>
      <li><strong>Local and reliable:</strong> We’re based nearby and understand the needs of Remus families.</li>
      <li><strong>Owner-operated:</strong> No middlemen—just a technician who shows up ready to work.</li>
      <li><strong>Quick turnaround:</strong> We respond fast and fix it right the first time.</li>
      <li><strong>No-pressure pricing:</strong> Honest estimates and clear communication.</li>
    </ul>
  </section>

  <section>
    <h2>Garage Door Services in Remus</h2>
    <p>We handle all types of residential garage door issues, including:</p>
    <ul>
      <li>Spring replacement and adjustment</li>
      <li>Garage door opener repair & installation</li>
      <li>Cable and roller repair</li>
      <li>Off-track and stuck doors</li>
      <li>Annual maintenance and tune-ups</li>
    </ul>
  </section>

  <section>
    <h2>Your Local Garage Door Expert</h2>
    <p>As a small business serving Central Michigan, we care about every job we take. Whether you’re in town or out on a back road, we’re just a call or click away. Try our <a href="/easyestimate">EasyEstimate™</a> tool to get started today.</p>
    <p><em>Raising Performance. Elevating Standards.</em></p>
  </section>
</BaseLayout>