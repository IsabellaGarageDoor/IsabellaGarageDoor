<!-- Highlight Section --> 
 <div class="highlight-section"> 
  <p> 
    Homeowners in Alma rely on <strong>Isabella Garage Door</strong> for honest repairs and dependable service. 
  </p> 
 </div>

<section class="cta-block">
  <h2 class="sub-heading">Get Your Garage Door Fixed Today</h2>
