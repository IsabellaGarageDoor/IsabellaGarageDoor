      "areaServed": {
        "@type": "City",
        "name": "Alma",
        "sameAs": "https://www.wikidata.org/wiki/Q953835" 
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Alma Service Offerings",
        "itemListElement": [
          {
            "@type": "Offer",
