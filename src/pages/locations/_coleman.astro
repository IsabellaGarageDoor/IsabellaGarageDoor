---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import LocationsFooter from '../../components/LocationsFooter.astro';

const title = "Garage Door Repair in Coleman, MI | Isabella Garage Door";
const description = "Reliable garage door repair and installation in Coleman, MI. Fast, local, and professional service from the family-owned team at Isabella Garage Door.";

const colemanSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://isabellagaragedoor.com/locations/coleman",
      "url": "https://isabellagaragedoor.com/locations/coleman",
      "name": "Garage Door Repair & Installation in Coleman, MI",
      "isPartOf": { "@id": "https://isabellagaragedoor.com/#website" },
      "description": "Professional garage door services for the Coleman community, including downtown and surrounding rural Midland County."
    },
    {
      "@type": "Service",
      "serviceType": "Garage Door Repair",
      "provider": { "@id": "https://isabellagaragedoor.com/#business" },
      "areaServed": {
        "@type": "City",
        "name": "Coleman",
        "sameAs": "https://www.wikidata.org/wiki/Q954109" 
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Coleman Service Menu",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Broken Spring Replacement" }
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "New Garage Door Installation" }
          }
        ]
      }
    }
  ]
};
---

<BaseLayout {title} {description}>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(colemanSchema)} />
  </Fragment>

<section class="hero">
  <h1>Garage Door Repair in Coleman, MI</h1>
  <p>Trusted, local service from a family-owned team. Fast repairs, expert installations, and long-term reliability—all right here in Coleman.</p>
</section>

<section class="services-overview">
  <h2>What We Do in Coleman</h2>
  <ul>
    <li><strong>Garage Door Repair:</strong> Broken springs, noisy rollers, off-track doors, and more.</li>
    <li><strong>Opener Repair & Replacement:</strong> Restore convenience with expert troubleshooting and upgrades.</li>
    <li><strong>New Doors & Installation:</strong> Boost curb appeal with professionally installed garage doors built to last.</li>
    <li><strong>Preventive Maintenance:</strong> Annual and seasonal tune-ups to keep your system safe and quiet.</li>
  </ul>
</section>

<section class="local-focus">
  <h2>Serving the Heart of Coleman</h2>
  <p>We know the homes, weather, and wear-and-tear common in Coleman. Whether you're near downtown, a few miles out, or tucked away on a country road—we show up fast, explain clearly, and get the job done right the first time.</p>
</section>

<section class="cta">
  <h2>Need Garage Door Service in Coleman?</h2>
  <p>Call us today or book online—we’re ready when you are.</p>
  <a href="/contact" class="btn">Schedule Service</a>
</section>

<section class="footer-tag">
  <h2 class="sub-heading">Isabella Garage Door</h2>
  <p style="font-size: .9rem; text-align: center;">
    Serving Coleman and surrounding areas with trusted garage door solutions.
  </p>
  <p style="font-size: .9rem; text-align: center; margin: 0.5rem;">
    <em>Raising Performance. Elevating Standards</em>
  </p>
</section>

<LocationsFooter currentPath="" slot="full-width-section" />

</BaseLayout>